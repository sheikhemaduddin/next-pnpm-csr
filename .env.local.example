# SB-CW-Emad — https://supabase.com/dashboard/project/vovazqystcxzqotxvbzs
# Copy to .env.local and fill keys from: Project Settings → API
#   cp .env.local.example .env.local

NEXT_PUBLIC_SUPABASE_URL=https://vovazqystcxzqotxvbzs.supabase.co

# Project Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the browser, never prefix with NEXT_PUBLIC_.
# Project Settings → API → Project API keys → service_role
# Bypasses RLS; only use via lib/supabase/admin.js for trusted admin operations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage bucket used by app/api/upload/route.js
SUPABASE_STORAGE_BUCKET=uploads
